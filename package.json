{
	"name": "svelte-portfolio",
	"private": true,
	"version": "1.10.5",
	"license": "MIT",
	"description": "A Svelte portfolio application with a Strapi backend",
	"author": {
		"name": "Mickaël Depardon",
		"email": "contact@mickael-depardon.com",
		"url": "https://www.mickael-depardon.com"
	},
	"engines": {
		"node": "24"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit package",
		"preview": "vite preview",
		"lint": "concurrently --max-processes=50% \"npm:eslint\" \"npm:prettier\" \"npm:stylelint\" \"npm:check\"",
		"format": "prettier --list-different --ignore-path .prettierignore --write './**/*.{cjs,js,ts,scss,css,yml,svelte,html,json}'",
		"eslint": "eslint .",
		"prettier": "prettier --ignore-path .prettierignore --check './**/*.{cjs,js,ts,scss,css,yml,svelte,html,json}'",
		"stylelint": "stylelint 'src/**/*.{css,scss,svelte}'",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"pretest": "svelte-kit sync",
		"release": "release-it --only-version"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@sveltekit-i18n/base": "^1.3.8",
		"@sveltekit-i18n/parser-default": "^1.1.1",
		"@types/accept-language-parser": "^1.5.8",
		"@types/node": "^24.10.2",
		"@types/slug": "^5.0.9",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"autoprefixer": "^10.5.2",
		"concurrently": "^10.0.3",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"postcss": "^8.5.16",
		"postcss-html": "^1.8.1",
		"prettier": "^3.9.1",
		"prettier-plugin-svelte": "^4.1.1",
		"release-it": "^20.2.1",
		"saas": "^1.0.0",
		"sass": "^1.101.0",
		"stylelint": "^17.14.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.2.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-preprocess": "^6.0.5",
		"sveltekit-i18n": "^2.4.2",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vite-plugin-node-polyfills": "^0.28.0"
	},
	"dependencies": {
		"@contentful/rich-text-html-renderer": "^17.2.2",
		"accept-language-parser": "^1.5.0",
		"axios": "^1.18.1",
		"contentful": "^11.12.6",
		"dayjs": "^1.11.21",
		"node-fetch": "^3.3.2",
		"node-mailjet": "^6.0.11",
		"query-string": "^9.4.1",
		"sanitize.css": "^13.0.0",
		"slug": "^11.0.1",
		"svelte-vertical-timeline": "^2.0.0",
		"typescript-eslint": "^8.62.0"
	},
	"overrides": {
		"undici": "7.28.0"
	},
	"allowScripts": {
		"svelte-preprocess@6.0.5": true,
		"esbuild@0.28.1": true,
		"@parcel/watcher@2.5.1": true,
		"fsevents@2.3.3": true
	}
}
